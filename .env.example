# Environment Variables Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env file!

# ============================================
# Qwen / Alibaba Cloud Configuration
# ============================================

# Your API key (required for Qwen)
QWEN_API_KEY=your-api-key-here

# API endpoint (optional, auto-detects based on mode)
# QWEN_BASE_URL=https://coding-intl.dashscope.aliyuncs.com/v1

# API mode: dashscope, openai, or anthropic (optional, auto-detects)
# QWEN_API_MODE=openai

# Model to use (optional, defaults vary by mode)
# QWEN_MODEL=qwen3-coder-plus

# ============================================
# Claude / Anthropic Configuration
# ============================================

# Your API key (required for Claude)
# ANTHROPIC_API_KEY=your-anthropic-api-key

# API endpoint (optional)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# ============================================
# Claw Code Configuration
# ============================================

# Max turns for AI conversation (optional)
# CLAW_MAX_TURNS=8

# Max budget tokens (optional)
# CLAW_MAX_TOKENS=2000

# ============================================
# ⚠️ SECURITY REMINDER
# ============================================
# 1. NEVER commit this file (.env)
# 2. Add .env to .gitignore (already done)
# 3. Use different keys for development and production
# 4. Rotate keys regularly
